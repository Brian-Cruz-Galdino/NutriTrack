# ==================================
# Variáveis de Ambiente - NutriTrack
# ==================================
# Este projeto usa localStorage, então não há variáveis
# de ambiente obrigatórias para banco de dados ou autenticação.
#
# Se futuramente migrar para Firebase/Supabase, adicione:
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL base da aplicação (opcional, usado para SEO)
NEXT_PUBLIC_APP_URL=http://localhost:3000
